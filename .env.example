# ── Divine Soul — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file to version control.

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/divine_soul
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/divine_soul
MONGODB_URI=mongodb://127.0.0.1:27017/divine_soul

# Secret key used to sign JWTs — use a long, random string in production
JWT_SECRET=change_me_to_a_long_random_secret_string_at_least_32_chars

# JWT expiry duration (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# Port the Express server listens on
PORT=5000

# Client origin for CORS (where your frontend is served from)
CLIENT_ORIGIN=http://127.0.0.1:5500
